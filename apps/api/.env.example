ENV=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/qihang
JWT_SECRET=CHANGE_ME
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=14
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CSRF_TTL_SECONDS=3600
