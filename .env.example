# Root-level shared examples
# Copy to `.env` for local Docker Compose.
# For server deploy, prefer `docker compose --env-file /path/to/mingrun.env ...`
# so secrets stay outside the repo.

# API
ENV=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/qihang
JWT_SECRET=CHANGE_ME
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=14
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CSRF_TTL_SECONDS=3600
REDIS_URL=redis://redis:6379/0
REDIS_NAMESPACE=qihang
S3_ENDPOINT=http://minio:9000
S3_PRESIGN_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PRIVATE_BUCKET=qihang-private
S3_DEMO_BUCKET=qihang-demo
S3_REGION=us-east-1
DEMO_MODE=true
DEMO_INFER_ENABLED=false
INFERENCE_ENDPOINT=
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_MAX_MB=50
UPLOAD_PUT_PROXY=false

# AI Model API (Alibaba Cloud DashScope)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
THINKING_CLASSIFIER_MODEL=qwen3.5-flash
THINKING_CLASSIFIER_MIN_CONFIDENCE=0.65
WEB_SEARCH_CLASSIFIER_MODEL=qwen3.5-flash
WEB_SEARCH_CLASSIFIER_MIN_CONFIDENCE=0.65

# Email / verification
# Gmail/Google Workspace SMTP: use an App Password here, never your normal login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=auto@mingrun-tech.com
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=auto@mingrun-tech.com
SMTP_FROM_NAME=铭润科技

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=QIHANG
NEXT_PUBLIC_DEMO_MAX_IMAGE_MB=10
NEXT_PUBLIC_ASSET_ORIGIN=http://localhost:9000

# Optional npm settings for Docker web builds.
# If the default registry is unstable on your network, switch to a nearby mirror,
# for example: https://registry.npmmirror.com
NPM_CONFIG_REGISTRY=https://registry.npmjs.org/
NPM_CONFIG_FETCH_RETRIES=5
NPM_CONFIG_FETCH_RETRY_FACTOR=2
NPM_CONFIG_FETCH_RETRY_MINTIMEOUT=20000
NPM_CONFIG_FETCH_RETRY_MAXTIMEOUT=120000
NPM_CONFIG_FETCH_TIMEOUT=300000

# Optional Docker base image mirrors.
# If Docker Hub times out on your network, point these at a reachable mirror.
# Example:
# PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.11-slim
# NODE_BASE_IMAGE=docker.m.daocloud.io/library/node:22-bookworm-slim
# POSTGRES_IMAGE=docker.m.daocloud.io/pgvector/pgvector:pg15
# REDIS_IMAGE=docker.m.daocloud.io/library/redis:7
# MINIO_IMAGE=docker.m.daocloud.io/minio/minio:latest
# MINIO_MC_IMAGE=docker.m.daocloud.io/minio/mc:latest
PYTHON_BASE_IMAGE=python:3.11-slim
NODE_BASE_IMAGE=node:22-bookworm-slim
POSTGRES_IMAGE=pgvector/pgvector:pg15
REDIS_IMAGE=redis:7
MINIO_IMAGE=minio/minio:latest
MINIO_MC_IMAGE=minio/mc:latest
